{
  "name": "nx-stylelint-src",
  "description": "Stylelint Plugin for Nx",
  "author": "Phillip Barta",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@10.33.2",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=22",
      "onFail": "error"
    },
    "packageManager": {
      "name": "pnpm",
      "version": ">=10.30.3",
      "onFail": "warn"
    }
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "scripts": {
    "nx": "nx",
    "build": "nx build",
    "test": "nx test",
    "prepare": "is-ci || husky",
    "release": "nx release --skip-publish --dry-run",
    "release:beta": "nx release prerelease --skip-publish --dry-run"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "9.39.4",
    "@nx/devkit": "22.6.5",
    "@nx/eslint": "22.6.5",
    "@nx/eslint-plugin": "22.6.5",
    "@nx/jest": "22.6.5",
    "@nx/js": "22.6.5",
    "@nx/plugin": "22.6.5",
    "@nx/workspace": "22.6.5",
    "@swc-node/register": "1.11.1",
    "@swc/cli": "0.8.1",
    "@swc/core": "1.15.30",
    "@swc/helpers": "0.5.21",
    "@types/jest": "30.0.0",
    "@types/node": "22.19.17",
    "@typescript-eslint/eslint-plugin": "8.59.0",
    "cosmiconfig": "9.0.1",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "husky": "9.1.7",
    "is-ci": "4.1.0",
    "jest": "30.3.0",
    "jest-environment-node": "30.3.0",
    "jest-util": "30.3.0",
    "jsonc-eslint-parser": "2.4.2",
    "memfs": "4.57.2",
    "nx": "22.6.5",
    "prettier": "3.8.3",
    "pretty-quick": "4.2.2",
    "stylelint": "17.9.0",
    "ts-jest": "29.4.9",
    "ts-node": "10.9.2",
    "tslib": "2.8.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.0",
    "verdaccio": "6.5.2"
  }
}
