{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "node20",
    "moduleResolution": "node16",
    "outDir": "../dist/out-tsc",
    "declaration": true,
    "types": ["node"],
    "removeComments": true
  },
  "exclude": [
    "**/*.spec.ts",
    "jest.config.ts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.tsx",
    "src/**/*.test.js",
    "src/**/*.spec.js",
    "src/**/*.test.jsx",
    "src/**/*.spec.jsx"
  ],
  "include": ["**/*.ts", "__mocks__/fs.cjs"]
}
